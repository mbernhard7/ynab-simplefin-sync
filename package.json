{
  "name": "ynab-simplefin-sync",
  "version": "3.0.0",
  "description": "Reconcile YNAB account balances against SimpleFIN Bridge.",
  "author": "Miles Bernhard <me@milesbernhard.com>",
  "license": "MIT",
  "homepage": "https://github.com/mbernhard7/ynab-simplefin-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbernhard7/ynab-simplefin-sync.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ynab-simplefin-sync": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/cli.js sync",
    "discover": "node dist/cli.js discover",
    "test": "npm run build && node --test dist-test/test/*.test.js",
    "pretest": "tsc -p tsconfig.test.json"
  },
  "keywords": [
    "ynab",
    "simplefin",
    "budget",
    "investments"
  ],
  "dependencies": {
    "ynab": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^7.0.0"
  }
}
